generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String?
  passwordHash String   @map("password_hash")
  avatarUrl    String?  @map("avatar_url")
  createdAt    DateTime @default(now()) @map("created_at")

  reports      Report[]

  @@map("users")
}

model Report {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  country   String
  committee String
  agenda    String
  status    String   @default("generating")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User            @relation(fields: [userId], references: [id])
  sections ReportSection[]

  @@map("reports")
}

model ReportSection {
  id         String @id @default(uuid())
  reportId   String @map("report_id")
  sectionType String @map("section_type")
  content    Json
  orderIndex Int    @map("order_index")

  report   Report     @relation(fields: [reportId], references: [id], onDelete: Cascade)
  citations Citation[]

  @@map("report_sections")
}

model Citation {
  id               String @id @default(uuid())
  reportSectionId  String @map("report_section_id")
  statementPreview String @map("statement_preview")
  url              String
  sourceName       String @map("source_name")
  accessedAt       DateTime @default(now()) @map("accessed_at")

  section ReportSection @relation(fields: [reportSectionId], references: [id], onDelete: Cascade)

  @@map("citations")
}

model SavedReport {
  userId   String   @map("user_id")
  reportId String   @map("report_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@id([userId, reportId])
  @@map("saved_reports")
}

model NewsCache {
  id         String   @id @default(uuid())
  sourceUrl  String   @unique @map("source_url")
  title      String
  content    String?
  fetchedAt  DateTime @default(now()) @map("fetched_at")
  category   String?

  @@map("news_cache")
}
