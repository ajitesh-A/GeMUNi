# OpenRouter API key (free models available)
# Sign up: https://openrouter.ai
OPENROUTER_API_KEY=

# LLM model to use (free tier models)
# Options: deepseek/deepseek-chat, qwen/qwen2.5-72b-instruct, meta-llama/llama-3.3-70b-instruct
LLM_MODEL=deepseek/deepseek-chat

# Database
DATABASE_URL=postgresql+asyncpg://gemuni:gemuni_dev@localhost:5432/gemuni

# Redis
REDIS_URL=redis://localhost:6379/0

# Chroma persistence directory
CHROMA_PERSIST_DIR=./chroma_data
