# SearXNG self-hosted search instance (fallback for keyword crawler)
# Deploy: see render.yaml searxng service
SEARXNG_BASE_URL=

# Groq API key (free, no billing required)
# Sign up: https://console.groq.com
GROQ_API_KEY=

# Gemini API key (free tier, no billing required)
# Get one: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenRouter API key (fallback when Gemini is unavailable)
# Sign up: https://openrouter.ai
OPENROUTER_API_KEY=

# LLM model to use (use :free suffix for free tier models)
# Options: openrouter/free (auto-best), meta-llama/llama-3.3-70b-instruct:free, deepseek/deepseek-r1:free
LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Database
DATABASE_URL=postgresql+asyncpg://gemuni:gemuni_dev@localhost:5432/gemuni

# Redis
REDIS_URL=redis://localhost:6379/0

# Chroma persistence directory
CHROMA_PERSIST_DIR=./chroma_data
